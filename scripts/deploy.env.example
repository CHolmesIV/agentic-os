# Copy to scripts/deploy.env (gitignored) and fill in your real VPS target.
# The deploy/push scripts source this automatically so the public repo never
# contains your host, user, or key path.
VPS_HOST="your-vps-host.example.com"
VPS_USER="deploy"
VPS_KEY="$HOME/.ssh/your_deploy_key"
REMOTE_DIR="/opt/agentic-os"
