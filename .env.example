# Copy to .env (gitignored) and fill in real values. Never commit real secrets.

# Telegram bot token from @BotFather (BotFather -> /newbot). Treat as a secret.
TELEGRAM_BOT_TOKEN=

# Your (operator) Telegram chat id — where alerts/digests are sent.
# Get your numeric user id from @userinfobot; for a personal 1:1 bot the
# chat id is usually the same number. See bot/README.md.
TELEGRAM_CHAT_ID=

# API key for Claude (used by routines invoking `claude -p` headless, and
# by any adapter/script that calls the Anthropic API directly).
ANTHROPIC_API_KEY=
