# Copy to .env (gitignored) and fill in real values. Never commit real secrets.
# This is the ONE place for every credential the orchestrator needs.
# Fill it in your normal editor, then run:  bash scripts/deploy-to-vps.sh
# (that script copies this file + your configs to the VPS — you never hand-edit
#  files over SSH again).

# ── Telegram ────────────────────────────────────────────────────────────────
# Bot token from @BotFather (/newbot). Treat as a secret.
TELEGRAM_BOT_TOKEN=
# Your numeric Telegram user id from @userinfobot. For a personal 1:1 bot the
# chat id is the same number. This is also what goes in config/systems.yml
# telegram.allowed_user_ids.
TELEGRAM_CHAT_ID=

# ── Claude ──────────────────────────────────────────────────────────────────
# API key for `claude -p` headless routines and any adapter calling Anthropic.
ANTHROPIC_API_KEY=

# ── Infrastructure adapters (fill as you wire each one; blank = that adapter
#    stays read-only / disabled) ───────────────────────────────────────────────
# Hostinger API token — enables DNS snapshot/write adapter (Tier 3).
HOSTINGER_API_TOKEN=
# Mailforge API key — enables mailbox/deliverability checks.
MAILFORGE_API_KEY=

# ── Form relay (known blocker — leave blank for now; forms stay "known-degraded"
#    until this exists) ─────────────────────────────────────────────────────────
# Gmail app password for the shared form-relay on the VPS.
GMAIL_APP_PASSWORD=
